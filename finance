from django.shortcuts import render
from django.contrib.auth.decorators import login_required
from django.db.models import Sum, Q, F, DecimalField
from django.db.models.functions import Coalesce
from django.utils import timezone
from datetime import timedelta
from decimal import Decimal
from django.core.cache import cache
from django.contrib import messages

from .gl.models import JournalEntryItem, ChartOfAccount, CustomerRefund, FinanceSettings
from .ar.models import CustomerInvoice
from .ap.models import VendorBill, BillPayment
from .banking.models import BankAccount
from purchase.models import SupplierCreditNote

# -----------------------------------------------

@login_required
def finance_dashboard(request):

    cache_key = "finance_dashboard_stats_global"

    context = cache.get(cache_key)

    if not context:
        settings_config = FinanceSettings.objects.first()
        if not settings_config:
            messages.warning(request, "Finance Settings not configured! Some charts may show 0 values.")

        today = timezone.now().date()
        thirty_days_ago = today - timedelta(days=30)

        receivables_q = CustomerInvoice.objects.filter(status__in=['Submitted', 'Partially Paid', 'Unpaid'])

        total_receivables_agg = receivables_q.annotate(
            total_paid=Coalesce(Sum('payments__amount_received'), Decimal(0))
        ).aggregate(
            balance_due=Coalesce(Sum(F('total_amount') - F('total_paid')), Decimal(0))
        )
        total_receivables = total_receivables_agg['balance_due']

        overdue_receivables = receivables_q.filter(due_date__lt=today)
        overdue_1_15 = overdue_receivables.filter(
            due_date__gte=today - timedelta(days=15)
        ).aggregate(total=Coalesce(Sum('total_amount'), Decimal(0)))['total']
        
        overdue_16_30 = overdue_receivables.filter(
            due_date__lt=today - timedelta(days=15), 
            due_date__gte=today - timedelta(days=30)
        ).aggregate(total=Coalesce(Sum('total_amount'), Decimal(0)))['total']
        
        overdue_31_45 = overdue_receivables.filter(
            due_date__lt=today - timedelta(days=30), 
            due_date__gte=today - timedelta(days=45)
        ).aggregate(total=Coalesce(Sum('total_amount'), Decimal(0)))['total']
        
        overdue_45_plus = overdue_receivables.filter(
            due_date__lt=today - timedelta(days=45)
        ).aggregate(total=Coalesce(Sum('total_amount'), Decimal(0)))['total']

        current_receivables_agg = receivables_q.filter(due_date__gte=today).annotate(
            total_paid=Coalesce(Sum('payments__amount_received'), Decimal(0))
        ).aggregate(
            balance_due=Coalesce(Sum(F('total_amount') - F('total_paid')), Decimal(0))
        )
        current_receivables = current_receivables_agg['balance_due']

        bills_due_qs = VendorBill.objects.filter(status__in=['Submitted', 'Partially Paid'])

        bills_stats = bills_due_qs.aggregate(
            total_bill=Coalesce(Sum('total_amount'), Decimal(0)),
            total_paid_or_credited=Coalesce(Sum('payments__amount_paid'), Decimal(0)) + Coalesce(Sum('payments__credit_applied'), Decimal(0))
        )
        total_bills_due = bills_stats['total_bill'] - bills_stats['total_paid_or_credited']

        total_supplier_credits = SupplierCreditNote.objects.filter(
            status__in=['Available', 'Partially Used']
        ).aggregate(total=Coalesce(Sum('amount_available'), Decimal(0)))['total']

        total_payables = total_bills_due - total_supplier_credits

        total_inventory_value = Decimal(0)
        inventory_account = settings_config.default_inventory_account if settings_config else None
        inventory_account_pk = inventory_account.pk if inventory_account else None
        
        if inventory_account:
            debits = JournalEntryItem.objects.filter(account=inventory_account).aggregate(total=Coalesce(Sum('debit'), Decimal(0)))['total']
            credits = JournalEntryItem.objects.filter(account=inventory_account).aggregate(total=Coalesce(Sum('credit'), Decimal(0)))['total']
            total_inventory_value = debits - credits

        cash_balance = Decimal(0)
        cash_account = settings_config.default_cash_account if settings_config else None
        
        if cash_account:
            debits = JournalEntryItem.objects.filter(account=cash_account).aggregate(total=Coalesce(Sum('debit'), Decimal(0)))['total']
            credits = JournalEntryItem.objects.filter(account=cash_account).aggregate(total=Coalesce(Sum('credit'), Decimal(0)))['total']
            cash_balance = debits - credits

        bank_accounts_balances = BankAccount.objects.filter(is_active=True)
        total_bank_balance = bank_accounts_balances.aggregate(total=Coalesce(Sum('current_balance'), Decimal(0)))['total']

        income_last_30_days = JournalEntryItem.objects.filter(
            journal_entry__date__gte=thirty_days_ago,
            journal_entry__date__lte=today,
            account__account_type='Revenue'
        ).aggregate(total=Coalesce(Sum('credit'), Decimal(0)) - Coalesce(Sum('debit'), Decimal(0)))['total']

        expense_last_30_days = JournalEntryItem.objects.filter(
            journal_entry__date__gte=thirty_days_ago,
            journal_entry__date__lte=today,
            account__account_type='Expense'
        ).aggregate(total=Coalesce(Sum('debit'), Decimal(0)) - Coalesce(Sum('credit'), Decimal(0)))['total']

        pending_refunds_qs = CustomerRefund.objects.filter(status='Pending')
        pending_refund_count = pending_refunds_qs.count()
        pending_refund_total = pending_refunds_qs.aggregate(
            total=Coalesce(Sum('refund_amount'), Decimal(0))
        )['total']

        context = {
            'title': 'Finance Dashboard',
            'total_receivables': total_receivables,
            'current_receivables': current_receivables,
            'overdue_1_15': overdue_1_15,
            'overdue_16_30': overdue_16_30,
            'overdue_31_45': overdue_31_45,
            'overdue_45_plus': overdue_45_plus,

            'total_payables': total_payables,
            'total_bills_due': total_bills_due,
            'total_supplier_credits': total_supplier_credits,
            'total_inventory_value': total_inventory_value,
            'inventory_account_pk': inventory_account_pk,
            'cash_balance': cash_balance,

            'total_bank_balance': total_bank_balance,
            'bank_accounts_balances': bank_accounts_balances,
            'income_last_30_days': income_last_30_days,
            'expense_last_30_days': expense_last_30_days,
            'pending_refund_count': pending_refund_count,
            'pending_refund_total': pending_refund_total,
        }

        cache.set(cache_key, context, 300)

    return render(request, 'finance/dashboard.html', context)
